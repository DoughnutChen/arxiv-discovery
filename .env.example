# arxiv-discovery 本地摘要生成配置示例
# 复制为 .env 后填写真实 API key；.env 已被 .gitignore 忽略。

ARXIV_DISCOVERY_PROVIDER=kimi
ARXIV_DISCOVERY_MODEL=moonshot-v1-32k
ARXIV_DISCOVERY_BASE_URL=https://api.moonshot.cn/v1
ARXIV_DISCOVERY_API_KEY_ENV=KIMI_API_KEY
KIMI_API_KEY=

# OpenAI 示例：
